---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "The Davinci Project - Digital asset transfer escrow protocol. Reliability and safety in an unsafe world." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://davinciproject.net" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-container">
        <a href="/" class="logo">
          <span class="logo-white">the </span>
          <span class="logo-green">davinci</span>
          <span class="logo-white"> project</span>
        </a>
        <nav class="main-nav">
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/blog">Blog</a>
          <a href="/docs">Docs</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-top">
          <div class="footer-brand">
            <div class="footer-logo">
              <span class="logo-white">the </span>
              <span class="logo-green">davinci</span>
              <span class="logo-white"> project</span>
            </div>
            <p class="footer-tagline">Digital asset transfer escrow protocol</p>
          </div>
          <div class="footer-links">
            <div class="footer-column">
              <h4>Product</h4>
              <a href="/embedded-finance">Embedded Finance</a>
              <a href="/baas">Banking as a Service</a>
              <a href="/open-banking">Open Banking</a>
              <a href="/payment-gateway">Payment Gateway</a>
            </div>
            <div class="footer-column">
              <h4>Company</h4>
              <a href="/about">About</a>
              <a href="/career">Careers</a>
              <a href="/press">Press</a>
              <a href="/contact">Contact</a>
            </div>
            <div class="footer-column">
              <h4>Resources</h4>
              <a href="/docs">Documentation</a>
              <a href="/api">API Reference</a>
              <a href="/blog">Blog</a>
              <a href="/help">Help Center</a>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <p>Copyright © 2026 The Davinci Foundation. All information contained herein is provided for informational purposes only and does not constitute financial advice.</p>
          <div class="footer-legal">
            <a href="/privacy">Privacy Policy</a>
            <a href="/terms">Terms of Service</a>
            <a href="/cookies">Cookie Policy</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg-primary: #000000;
    --bg-secondary: #0a0a0a;
    --bg-card: #111111;
    --text-primary: #ffffff;
    --text-secondary: #a0a0a0;
    --accent-green: #00ff88;
    --accent-pink: #ff4081;
    --accent-blue: #2962ff;
    --accent-yellow: #ffd600;
    --accent-cyan: #00e5ff;
    --border: #1a1a1a;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
  }

  /* Header */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .logo-white {
    color: var(--text-primary);
  }

  .logo-green {
    color: var(--accent-green);
  }

  .main-nav {
    display: flex;
    gap: 2rem;
  }

  .main-nav a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s;
  }

  .main-nav a:hover {
    color: var(--accent-green);
  }

  /* Footer */
  .site-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    padding: 4rem 2rem 2rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    margin-bottom: 3rem;
    gap: 4rem;
  }

  .footer-brand {
    flex: 0 0 auto;
  }

  .footer-logo {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .footer-links {
    display: flex;
    gap: 4rem;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-column h4 {
    color: var(--text-primary);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .footer-column a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s;
  }

  .footer-column a:hover {
    color: var(--accent-green);
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom p {
    color: var(--text-secondary);
    font-size: 0.8rem;
    max-width: 600px;
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer-legal a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    transition: color 0.3s;
  }

  .footer-legal a:hover {
    color: var(--accent-green);
  }

  /* Mobile Responsive */
  @media (max-width: 968px) {
    .header-container {
      flex-direction: column;
      gap: 1rem;
    }

    .main-nav {
      gap: 1rem;
    }

    .footer-top {
      flex-direction: column;
      gap: 2rem;
    }

    .footer-links {
      flex-wrap: wrap;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }

  @media (max-width: 600px) {
    .header-container {
      padding: 1rem;
    }

    .main-nav {
      flex-wrap: wrap;
      justify-content: center;
    }

    .footer-links {
      flex-direction: column;
      gap: 1.5rem;
    }
  }
</style>
