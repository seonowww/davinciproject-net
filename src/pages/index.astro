---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Davinci Project - Renewed">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <h1>
          <span class="text-white">the </span>
          <span class="text-green">davinci</span>
          <span class="text-white"> project</span>
        </h1>
        <h2 class="renewed">renewed</h2>
      </div>
      <div class="hero-logo">
        <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
          <g transform="translate(100, 100) rotate(45)">
            <!-- Outer layer -->
            <rect x="-80" y="-80" width="160" height="160" fill="none" stroke="#00ff88" stroke-width="8" rx="8"/>
            <rect x="-60" y="-60" width="120" height="120" fill="none" stroke="#ff4081" stroke-width="8" rx="8"/>
            <rect x="-40" y="-40" width="80" height="80" fill="none" stroke="#00e5ff" stroke-width="8" rx="8"/>
            <rect x="-20" y="-20" width="40" height="40" fill="none" stroke="#ffffff" stroke-width="8" rx="8"/>
            <!-- Corner accents -->
            <line x1="-90" y1="-90" x2="-70" y2="-70" stroke="#2962ff" stroke-width="8" stroke-linecap="round"/>
            <line x1="90" y1="-90" x2="70" y2="-70" stroke="#2962ff" stroke-width="8" stroke-linecap="round"/>
            <line x1="-90" y1="90" x2="-70" y2="70" stroke="#2962ff" stroke-width="8" stroke-linecap="round"/>
            <line x1="90" y1="90" x2="70" y2="70" stroke="#2962ff" stroke-width="8" stroke-linecap="round"/>
            <!-- Inner accents -->
            <line x1="-50" y1="-50" x2="-30" y2="-30" stroke="#00ff88" stroke-width="6" stroke-linecap="round"/>
            <line x1="50" y1="-50" x2="30" y2="-30" stroke="#ff4081" stroke-width="6" stroke-linecap="round"/>
            <line x1="-50" y1="50" x2="-30" y2="30" stroke="#ff4081" stroke-width="6" stroke-linecap="round"/>
            <line x1="50" y1="50" x2="30" y2="30" stroke="#00ff88" stroke-width="6" stroke-linecap="round"/>
          </g>
        </svg>
      </div>
    </div>
    <div class="hero-buttons">
      <a href="https://huobi.com" class="btn btn-blue" target="_blank" rel="noopener">HUOBI</a>
      <a href="https://hotbit.io" class="btn btn-yellow" target="_blank" rel="noopener">HOTBIT</a>
    </div>
  </section>

  <!-- Announcement Section -->
  <section class="announcement">
    <div class="announcement-container">
      <div class="announcement-text">
        <p class="announcement-main">The Davinci Project has re-launched under new management. Join us in our new mission!</p>
        <p class="announcement-quote">"Crypto is a vaccine against tyranny"</p>
        <p class="announcement-description">The new Davinci Project is a digital asset transfer escrow protocol. We provide reliability and safety in an unsafe world.</p>
      </div>
      <a href="/about" class="learn-more">LEARN MORE</a>
    </div>
  </section>

  <!-- Roadmap Section -->
  <section class="roadmap">
    <div class="roadmap-container">
      <h2 class="roadmap-title">DAVINCI PROJECT ROADMAP</h2>
      <div class="roadmap-timeline">
        <div class="roadmap-item">
          <div class="roadmap-marker completed"></div>
          <div class="roadmap-content">
            <span class="roadmap-quarter">Q1 '22</span>
            <span class="roadmap-label">Project Re-Launch</span>
          </div>
        </div>
        <div class="roadmap-item">
          <div class="roadmap-marker completed"></div>
          <div class="roadmap-content">
            <span class="roadmap-quarter">Q2 '22</span>
            <span class="roadmap-label">Mission Update</span>
          </div>
        </div>
        <div class="roadmap-item">
          <div class="roadmap-marker completed"></div>
          <div class="roadmap-content">
            <span class="roadmap-quarter">Q3 '22</span>
            <span class="roadmap-label">Global Partnerships</span>
          </div>
        </div>
        <div class="roadmap-item">
          <div class="roadmap-marker completed"></div>
          <div class="roadmap-content">
            <span class="roadmap-quarter">Q4 '22</span>
            <span class="roadmap-label">Service Launch</span>
          </div>
        </div>
        <div class="roadmap-item">
          <div class="roadmap-marker completed"></div>
          <div class="roadmap-content">
            <span class="roadmap-quarter">Q1 '23</span>
            <span class="roadmap-label">Blockchain Update</span>
          </div>
        </div>
        <div class="roadmap-item">
          <div class="roadmap-marker current"></div>
          <div class="roadmap-content">
            <span class="roadmap-quarter">Q2 '23</span>
            <span class="roadmap-label">Automation Completed</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Join Section -->
  <section class="join">
    <div class="join-container">
      <h2 class="join-title">JOIN NOW</h2>
      <div class="join-content">
        <div class="join-info">
          <h3 class="join-heading">Buy DAC, Join the Network</h3>
          <p class="join-subheading">The Davinci Coin is currently traded on these exchanges:</p>
          <div class="exchanges">
            <a href="https://huobi.com" class="exchange-link" target="_blank" rel="noopener">Huobi Global</a>
            <a href="https://hotbit.io" class="exchange-link" target="_blank" rel="noopener">Hotbit</a>
          </div>
          <blockquote class="join-quote">
            "It had long since come to my attention that people of accomplishment rarely sat back and let things happen to them. They went out and happened to things." — Leonardo daVinci
          </blockquote>
        </div>
        <div class="join-logo">
          <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <g transform="translate(100, 100) rotate(45)">
              <rect x="-80" y="-80" width="160" height="160" fill="none" stroke="#00ff88" stroke-width="8" rx="8"/>
              <rect x="-60" y="-60" width="120" height="120" fill="none" stroke="#ff4081" stroke-width="8" rx="8"/>
              <rect x="-40" y="-40" width="80" height="80" fill="none" stroke="#00e5ff" stroke-width="8" rx="8"/>
              <rect x="-20" y="-20" width="40" height="40" fill="none" stroke="#ffffff" stroke-width="8" rx="8"/>
              <line x1="-90" y1="-90" x2="-70" y2="-70" stroke="#2962ff" stroke-width="8" stroke-linecap="round"/>
              <line x1="90" y1="-90" x2="70" y2="-70" stroke="#2962ff" stroke-width="8" stroke-linecap="round"/>
              <line x1="-90" y1="90" x2="-70" y2="70" stroke="#2962ff" stroke-width="8" stroke-linecap="round"/>
              <line x1="90" y1="90" x2="70" y2="70" stroke="#2962ff" stroke-width="8" stroke-linecap="round"/>
              <line x1="-50" y1="-50" x2="-30" y2="-30" stroke="#ffd600" stroke-width="6" stroke-linecap="round"/>
              <line x1="50" y1="-50" x2="30" y2="-30" stroke="#ffd600" stroke-width="6" stroke-linecap="round"/>
              <line x1="-50" y1="50" x2="-30" y2="30" stroke="#ff4081" stroke-width="6" stroke-linecap="round"/>
              <line x1="50" y1="50" x2="30" y2="30" stroke="#00ff88" stroke-width="6" stroke-linecap="round"/>
            </g>
          </svg>
        </div>
      </div>
      <div class="social-section">
        <h3 class="social-title">Follow us</h3>
        <div class="social-links">
          <a href="#" class="social-link" aria-label="Twitter">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Telegram">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18 1.897-.962 6.502-1.359 8.627-.168.9-.5 1.201-.82 1.23-.697.064-1.226-.461-1.901-.903-1.056-.693-1.653-1.124-2.678-1.8-1.185-.781-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.831-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635.099-.002.321.023.465.141.121.099.154.232.17.325.015.093.034.305.019.471z"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Medium">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 6rem 2rem 4rem;
    text-align: center;
  }

  .hero-content {
    display: flex;
    align-items: center;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .hero-text h1 {
    font-size: 3rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .text-white {
    color: var(--text-primary);
  }

  .text-green {
    color: var(--accent-green);
  }

  .renewed {
    font-size: 2.5rem;
    color: var(--accent-pink);
    font-weight: 400;
  }

  .hero-logo svg {
    width: 250px;
    height: 250px;
  }

  .hero-buttons {
    display: flex;
    gap: 2rem;
  }

  .btn {
    padding: 1rem 3rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 4px;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
  }

  .btn-blue {
    background: var(--accent-blue);
    color: white;
  }

  .btn-yellow {
    background: var(--accent-yellow);
    color: #000;
  }

  /* Announcement Section */
  .announcement {
    background: var(--accent-green);
    padding: 4rem 2rem;
  }

  .announcement-container {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
  }

  .announcement-text {
    flex: 1;
  }

  .announcement-main {
    color: #000;
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .announcement-quote {
    color: #fff;
    font-size: 1.5rem;
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  .announcement-description {
    color: #000;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.5;
  }

  .learn-more {
    color: var(--accent-blue);
    font-size: 2.5rem;
    font-weight: 700;
    text-decoration: none;
    padding-left: 2rem;
    border-left: 6px solid #fff;
    white-space: nowrap;
    transition: transform 0.3s;
  }

  .learn-more:hover {
    transform: translateX(10px);
  }

  /* Roadmap Section */
  .roadmap {
    background: #fff;
    padding: 4rem 2rem;
  }

  .roadmap-container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .roadmap-title {
    color: #000;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 3rem;
  }

  .roadmap-timeline {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .roadmap-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .roadmap-marker {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    margin-bottom: 0.5rem;
  }

  .roadmap-marker.completed {
    background: var(--accent-yellow);
  }

  .roadmap-marker.current {
    background: var(--accent-blue);
    box-shadow: 0 0 0 6px rgba(41, 98, 255, 0.2);
  }

  .roadmap-content {
    text-align: center;
  }

  .roadmap-quarter {
    display: block;
    color: #000;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .roadmap-label {
    display: block;
    color: #666;
    font-size: 0.75rem;
  }

  /* Join Section */
  .join {
    background: var(--bg-primary);
    padding: 4rem 2rem;
  }

  .join-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .join-title {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 3rem;
    padding-left: 2rem;
    border-left: 6px solid var(--accent-blue);
    display: inline-block;
  }

  .join-content {
    display: flex;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .join-info {
    flex: 1;
  }

  .join-heading {
    color: var(--accent-yellow);
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .join-subheading {
    color: var(--accent-pink);
    font-size: 1.25rem;
    margin-bottom: 2rem;
  }

  .exchanges {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .exchange-link {
    color: var(--accent-blue);
    font-size: 1.25rem;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s;
  }

  .exchange-link:hover {
    color: var(--accent-green);
  }

  .join-quote {
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.6;
    font-style: italic;
    border-left: none;
    padding-left: 0;
  }

  .join-logo svg {
    width: 300px;
    height: 300px;
  }

  .social-section {
    margin-top: 3rem;
  }

  .social-title {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
  }

  .social-link {
    color: var(--text-primary);
    transition: color 0.3s;
  }

  .social-link:hover {
    color: var(--accent-green);
  }

  /* Mobile Responsive */
  @media (max-width: 968px) {
    .hero-content {
      flex-direction: column;
      gap: 2rem;
    }

    .hero-text h1 {
      font-size: 2.5rem;
    }

    .renewed {
      font-size: 2rem;
    }

    .announcement-container {
      flex-direction: column;
      text-align: center;
    }

    .learn-more {
      padding-left: 0;
      border-left: none;
      border-bottom: 6px solid #fff;
      padding-bottom: 1rem;
    }

    .join-content {
      flex-direction: column;
    }

    .join-logo {
      order: -1;
      text-align: center;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: 5rem 1rem 3rem;
    }

    .hero-text h1 {
      font-size: 2rem;
    }

    .renewed {
      font-size: 1.5rem;
    }

    .hero-logo svg {
      width: 180px;
      height: 180px;
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
    }

    .btn {
      text-align: center;
    }

    .announcement {
      padding: 3rem 1rem;
    }

    .announcement-quote {
      font-size: 1.25rem;
    }

    .learn-more {
      font-size: 2rem;
    }

    .roadmap-timeline {
      flex-direction: column;
    }

    .join {
      padding: 3rem 1rem;
    }

    .join-logo svg {
      width: 200px;
      height: 200px;
    }
  }
</style>
